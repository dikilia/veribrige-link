{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/gen",
      "dest": "/public/gen/index.html"
    },
    {
      "src": "/gen/(.*)",
      "dest": "/public/gen/index.html"
    },
    {
      "src": "/admin",
      "dest": "/public/admin/index.html"
    },
    {
      "src": "/admin/dashboard",
      "dest": "/public/admin/dashboard.html"
    },
    {
      "src": "/verify.html",
      "dest": "/public/verify.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/gen/index.html"
    }
  ]
}